@model IEnumerable<AnimalRescueApp.Models.Animal>

@{
    ViewData["Title"] = "قائمة الحيوانات";
}

<div class="container mt-4" dir="rtl" style="text-align: right;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold">🐾 الحيوانات التي تم إنقاذها</h2>

        <form asp-action="Index" method="get" class="d-flex ms-auto me-3">
            <div class="input-group">
                <input type="text" name="searchString" class="form-control" placeholder="ابحث باسم الحيوان أو نوعه..." style="max-width: 300px;" />
                <button type="submit" class="btn btn-outline-primary">بحث 🔍</button>
            </div>
        </form>

        <a asp-action="Create" class="btn btn-primary fw-bold px-4">+ إضافة حيوان جديد</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center" role="alert">
            لا توجد حيوانات مسجلة حالياً. اضغطي على زر "إضافة حيوان جديد" للبدء!
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="@item.ImageURL" class="card-img-top" alt="@item.Name" style="height: 200px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title text-primary fw-bold">@item.Name</h5>
                            <p class="card-text mb-1"><strong>النوع:</strong> @item.Species</p>
                            <p class="card-text mb-1"><strong>العمر:</strong> @item.Age سنة</p>
                            <p class="card-text text-muted"><strong>الحالة الصحية:</strong> @item.HealthStatus</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>